---
import Layout from "../layouts/Layout.astro";
---

<Layout>
  <!-- ── Hero ──────────────────────────────────────────────────── -->
  <section class="hero">
    <div class="hero-grid" aria-hidden="true"></div>

    <div class="hero-float" aria-hidden="true">
      <span class="hero-float-mark hf-onshape" title="Onshape">
        <img src="/onshape.svg" alt="" />
      </span>
      <span class="hero-float-mark hf-codex" title="Codex">
        <img src="/harnesses/openai_dark.svg" alt="" />
      </span>
      <span class="hero-float-mark hf-cadsense" title="CadSense">
        <img src="/cadsense-logo.png" alt="" />
      </span>
      <span class="hero-float-mark hf-solidworks" title="SolidWorks">
        <img src="/solidworks.png" alt="" />
      </span>
    </div>

    <div class="container hero-inner">
      <h1 class="hero-title display">
        Catch small CAD<br />mistakes before<br />they ship.
      </h1>

      <p class="hero-sub">
        CadSense gives Codex the model context it needs to review CAD changes,
        flag visual issues, and keep fixes tied to the design.
      </p>

      <div class="hero-actions">
        <a
          id="download-btn"
          href="https://github.com/AadiJo/cadsense/releases"
          class="btn btn-primary btn-lg"
        >
          <svg class="dl-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 88 88" aria-hidden="true"><path fill="currentColor" d="m0 12.402 35.687-4.86.016 34.423-35.67.203zm35.67 33.529.028 34.453L.028 75.48.026 45.7zm4.326-39.025L87.314 0v41.527l-47.318.376zm47.329 39.349-.011 41.34-47.318-6.678-.066-34.739z"/></svg>
          <span>Download for Windows</span>
        </a>
        <a href="https://github.com/AadiJo/cadsense" target="_blank" rel="noopener noreferrer" class="btn btn-ghost btn-lg">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M12 .5C5.65.5.5 5.65.5 12a11.5 11.5 0 007.86 10.93c.58.1.79-.25.79-.56v-2c-3.2.69-3.88-1.37-3.88-1.37-.52-1.33-1.27-1.69-1.27-1.69-1.04-.71.08-.7.08-.7 1.15.08 1.76 1.18 1.76 1.18 1.02 1.76 2.68 1.25 3.33.96.1-.75.4-1.25.72-1.54-2.55-.29-5.24-1.27-5.24-5.67 0-1.25.45-2.28 1.18-3.08-.12-.29-.51-1.45.11-3.02 0 0 .96-.31 3.15 1.18a10.96 10.96 0 015.74 0c2.19-1.49 3.15-1.18 3.15-1.18.62 1.57.23 2.73.11 3.02.74.8 1.18 1.83 1.18 3.08 0 4.41-2.7 5.38-5.27 5.66.41.36.78 1.06.78 2.13v3.16c0 .31.21.67.8.56A11.5 11.5 0 0023.5 12C23.5 5.65 18.35.5 12 .5z"/>
          </svg>
          Star on GitHub
        </a>
      </div>

      <div class="hero-preview">
        <figure class="hero-screenshot-frame">
          <div class="hero-screenshot-placeholder" aria-label="Placeholder for upcoming CadSense product screenshot">
            <span>Product screenshot coming here</span>
          </div>
        </figure>
      </div>
    </div>
  </section>

  <!-- ── Harnesses ─────────────────────────────────────────────── -->
  <section id="harnesses" class="sec-harness">
    <div class="container">
      <div class="section-head">
        <h2>Bring your own Codex login.</h2>
        <p>
          Codex is supported today. Claude Code, OpenCode, and Cursor are on
          the roadmap, but the current focus is making Codex useful for CAD
          review and early mistake detection.
        </p>
      </div>

      <div class="harness-grid">
        <div class="harness is-supported">
          <div class="harness-mark"><img src="/harnesses/openai_dark.svg" alt="" /></div>
          <div class="harness-meta">
            <div class="harness-name">Codex CLI</div>
            <div class="harness-tag">Supported now · codex login</div>
          </div>
        </div>
        <div class="harness is-coming-soon">
          <div class="harness-mark"><img src="/harnesses/claude-ai-icon.svg" alt="" /></div>
          <div class="harness-meta">
            <div class="harness-name">Claude Code</div>
            <div class="harness-tag">Coming soon</div>
          </div>
        </div>
        <div class="harness is-coming-soon">
          <div class="harness-mark"><img src="/harnesses/opencode-dark.svg" alt="" /></div>
          <div class="harness-meta">
            <div class="harness-name">OpenCode</div>
            <div class="harness-tag">Coming soon</div>
          </div>
        </div>
        <div class="harness is-coming-soon">
          <div class="harness-mark"><img src="/harnesses/cursor_light.svg" alt="" /></div>
          <div class="harness-meta">
            <div class="harness-name">Cursor</div>
            <div class="harness-tag">Coming soon</div>
          </div>
        </div>
      </div>

      <div class="harness-footer">
        <div class="harness-footer-item"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4 12l5 5L20 6"/></svg> Uses your existing Codex auth.</div>
        <div class="harness-footer-item"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4 12l5 5L20 6"/></svg> Built around CAD review, screenshots, and model context.</div>
        <div class="harness-footer-item"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4 12l5 5L20 6"/></svg> Other agent harnesses are coming later.</div>
      </div>
    </div>
  </section>

  <!-- ── Git ──────────────────────────────────────────────────── -->
  <section id="git" class="sec-git">
    <div class="container git-inner">
      <div class="git-visual">
        <div class="review-card tile">
          <div class="review-head">
            <div>
              <div class="review-label">CAD review</div>
              <span class="review-title">Front bracket alignment check</span>
            </div>
          </div>
          <div class="review-meta">
            <span>Assembly: `Upper hinge`</span>
            <span>View: `Section A-A`</span>
            <span>Risk: medium</span>
          </div>
          <div class="review-canvas">
            <div class="review-shape review-shape-main"></div>
            <div class="review-shape review-shape-tab"></div>
            <div class="review-axis review-axis-x"></div>
            <div class="review-axis review-axis-y"></div>
            <div class="review-pin review-pin-a">
              <span class="review-pin-dot"></span>
              <div class="review-note">
                <div class="review-note-head">
                  <span class="review-severity review-severity-high">Clearance</span>
                  <span class="review-note-index">01</span>
                </div>
                <p>Boss edge is only 0.4 mm from the wall. Flag for interference after print shrink.</p>
              </div>
            </div>
            <div class="review-pin review-pin-b">
              <span class="review-pin-dot"></span>
              <div class="review-note">
                <div class="review-note-head">
                  <span class="review-severity review-severity-mid">Alignment</span>
                  <span class="review-note-index">02</span>
                </div>
                <p>Hole center drifts off datum by 0.8 mm. Recheck mate before release.</p>
              </div>
            </div>
          </div>
          <div class="review-list">
            <div class="review-list-row">
              <span class="review-list-tag">Next</span>
              <span>Adjust fillet and hole position, then rerun the review capture.</span>
            </div>
            <div class="review-list-row">
              <span class="review-list-tag review-list-tag-soft">Context</span>
              <span>Notes stay attached to the same screenshot, model, and Codex thread.</span>
            </div>
          </div>
          <div class="review-foot">
            <button class="btn btn-ghost" style="font-size:12px;padding:6px 10px">Open comments</button>
            <button class="btn btn-primary" style="font-size:12px;padding:6px 12px">Generate fix plan</button>
          </div>
        </div>
        <div class="review-trail">
          <div class="review-trail-dot"></div>
          <div class="review-trail-line"></div>
          <div class="review-trail-dot"></div>
        </div>
        <div class="review-button-shell">
          <button class="review-button">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M3 12h5"/><path d="M16 12h5"/><path d="M12 3v5"/><path d="M12 16v5"/><circle cx="12" cy="12" r="3.5"/></svg>
            Step through findings
            <span class="review-button-kbd">N</span>
          </button>
        </div>
      </div>

      <div class="git-copy">
        <div class="section-head" style="margin-bottom:0">
          <h2>Turn review findings into fixes while the context is fresh.</h2>
          <p>
            Small CAD mistakes are cheapest when they are caught before handoff.
            CadSense keeps screenshots, pinned comments, and Codex follow-up in one
            place so each note stays tied to the exact geometry that needs attention.
          </p>
          <ul class="checklist" style="margin-top:24px">
            <li><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4 12l5 5L20 6"/></svg> Mark up the exact face, edge, or hole that looks wrong.</li>
            <li><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4 12l5 5L20 6"/></svg> Capture small fit, clearance, and alignment issues before they snowball.</li>
            <li><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4 12l5 5L20 6"/></svg> Move from review notes to a concrete fix plan without losing context.</li>
            <li><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4 12l5 5L20 6"/></svg> Keep the review trail attached to the same model and screenshot set.</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- ── Open source ───────────────────────────────────────────── -->

  <!-- ── Final CTA ─────────────────────────────────────────────── -->
  <section id="download" class="sec-cta">
    <div class="container cta-inner">
      <h2 class="display cta-title">
        Catch CAD mistakes earlier.
      </h2>
      <p class="cta-sub">
        Install CadSense, connect Codex, and run a focused CAD review before
        small issues make it into the next handoff.
      </p>
      <div class="cta-actions">
        <a id="cta-download-btn" class="btn btn-primary btn-lg" href="https://github.com/AadiJo/cadsense/releases">
          <svg class="dl-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 88 88" aria-hidden="true"><path fill="currentColor" d="m0 12.402 35.687-4.86.016 34.423-35.67.203zm35.67 33.529.028 34.453L.028 75.48.026 45.7zm4.326-39.025L87.314 0v41.527l-47.318.376zm47.329 39.349-.011 41.34-47.318-6.678-.066-34.739z"/></svg>
          <span>Download for Windows</span>
        </a>
      </div>
    </div>
  </section>
</Layout>

<script>
  import { fetchLatestRelease, RELEASES_URL, type ReleaseAsset } from "../lib/releases";

  function pickWindowsAsset(assets: ReleaseAsset[]): string | null {
    return assets.find((a) => a.name.endsWith("-x64.exe"))?.browser_download_url ?? null;
  }

  async function init() {
    const btn = document.getElementById("download-btn") as HTMLAnchorElement | null;
    const ctaBtn = document.getElementById("cta-download-btn") as HTMLAnchorElement | null;

    try {
      const release = await fetchLatestRelease();
      const url = pickWindowsAsset(release.assets ?? []);
      if (url) {
        if (btn) {
          btn.href = url;
          btn.removeAttribute("target");
          btn.removeAttribute("rel");
        }
        if (ctaBtn) {
          ctaBtn.href = url;
          ctaBtn.removeAttribute("target");
          ctaBtn.removeAttribute("rel");
        }
      }
    } catch {
      if (btn) btn.href = RELEASES_URL;
      if (ctaBtn) ctaBtn.href = RELEASES_URL;
    }
  }

  init();
</script>

<style>
  /* ── Section base ─────────────────────────────────────────── */
  section {
    position: relative;
    padding: 96px 0;
    border-top: 1px solid var(--border);
  }

  .section-head {
    margin-bottom: 56px;
    max-width: 720px;
  }

  .section-head .eyebrow {
    margin-bottom: 14px;
    display: block;
  }

  .section-head h2 {
    font-size: clamp(32px, 4vw, 48px);
    font-weight: 500;
    letter-spacing: -0.035em;
    line-height: 1.05;
    margin-bottom: 18px;
  }

  .section-head p {
    color: var(--fg-muted);
    font-size: 18px;
    max-width: 620px;
    letter-spacing: -0.005em;
  }

  .checklist {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .checklist li {
    display: flex;
    align-items: center;
    gap: 10px;
    color: var(--fg-muted);
    font-size: 15px;
  }

  .checklist li svg {
    color: var(--ok);
    flex-shrink: 0;
  }

  /* ── Hero ─────────────────────────────────────────────────── */
  .hero {
    padding: 72px 0 60px;
    position: relative;
    overflow: hidden;
    border-top: 0;
  }

  .hero-grid {
    position: absolute;
    inset: 0;
    pointer-events: none;
    background-image:
      linear-gradient(to right, rgba(255, 255, 255, 0.035) 1px, transparent 1px),
      linear-gradient(to bottom, rgba(255, 255, 255, 0.035) 1px, transparent 1px);
    background-size: 48px 48px;
    mask-image: radial-gradient(ellipse 80% 60% at 50% 40%, black 40%, transparent 100%);
    -webkit-mask-image: radial-gradient(ellipse 80% 60% at 50% 40%, black 40%, transparent 100%);
  }

  .hero-inner {
    position: relative;
    text-align: center;
  }

  .hero-title {
    font-size: clamp(38px, 5.6vw, 76px);
    margin: 28px auto 22px;
    max-width: 20ch;
    text-wrap: balance;
  }

  .hero-sub {
    color: var(--fg-muted);
    font-size: clamp(16px, 1.4vw, 19px);
    max-width: 640px;
    margin: 0 auto 36px;
    letter-spacing: -0.005em;
    line-height: 1.55;
  }

  .hero-actions {
    display: flex;
    gap: 10px;
    justify-content: center;
    flex-wrap: wrap;
    margin-bottom: 56px;
  }

  .dl-icon {
    display: block;
    width: 14px;
    height: 14px;
    flex-shrink: 0;
  }

  /* Floating harness marks */
  .hero-float {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 1;
  }

  .hero-float-mark {
    position: absolute;
    width: 96px;
    height: 96px;
    border-radius: 24px;
    display: grid;
    place-items: center;
    background: rgba(20, 20, 24, 0.9);
    border: 1px solid var(--border);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    box-shadow:
      0 20px 48px -16px rgba(0, 0, 0, 0.65),
      0 2px 0 0 rgba(255, 255, 255, 0.04) inset;
    animation: floatDrift 9s ease-in-out infinite;
  }

  .hero-float-mark img {
    width: 54px;
    height: 54px;
    display: block;
    object-fit: contain;
  }

  .hero-float-mark.hf-cadsense img {
    width: 58px;
    height: 58px;
  }

  .hero-float-mark.hf-onshape  { background: radial-gradient(circle at 30% 25%, rgba(32, 201, 122, 0.28), rgba(20, 20, 24, 0.92) 65%); top: 8%;  left: 7%;  animation-delay: 0s;    transform: rotate(-8deg); box-shadow: 0 22px 52px -18px rgba(32, 201, 122, 0.72), 0 0 34px rgba(32, 201, 122, 0.22), 0 2px 0 0 rgba(255, 255, 255, 0.04) inset; }
  .hero-float-mark.hf-codex    { background: radial-gradient(circle at 30% 25%, rgba(255, 255, 255, 0.12), rgba(20, 20, 24, 0.92) 65%); top: 6%;  right: 7%; animation-delay: -2.5s; transform: rotate(6deg); box-shadow: 0 20px 48px -16px rgba(255, 255, 255, 0.24), 0 0 24px rgba(255, 255, 255, 0.12), 0 2px 0 0 rgba(255, 255, 255, 0.04) inset; }
  .hero-float-mark.hf-cadsense { background: radial-gradient(circle at 30% 25%, rgba(74, 144, 226, 0.22), rgba(20, 20, 24, 0.92) 65%); top: 32%; left: 5%;  animation-delay: -5s;   transform: rotate(4deg); box-shadow: 0 20px 48px -16px rgba(74, 144, 226, 0.38), 0 0 26px rgba(74, 144, 226, 0.16), 0 2px 0 0 rgba(255, 255, 255, 0.04) inset; }
  .hero-float-mark.hf-solidworks { background: radial-gradient(circle at 30% 25%, rgba(255, 88, 88, 0.22), rgba(20, 20, 24, 0.92) 65%); top: 30%; right: 5%; animation-delay: -7s;   transform: rotate(-5deg); box-shadow: 0 20px 48px -16px rgba(255, 88, 88, 0.38), 0 0 26px rgba(255, 88, 88, 0.16), 0 2px 0 0 rgba(255, 255, 255, 0.04) inset; }

  @media (max-width: 1180px) {
    .hero-float-mark { width: 76px; height: 76px; border-radius: 20px; }
    .hero-float-mark img { width: 42px; height: 42px; }
    .hero-float-mark.hf-cadsense img { width: 46px; height: 46px; }
    .hero-float-mark.hf-onshape  { top: 4%;  left: 3%; }
    .hero-float-mark.hf-codex    { top: 2%;  right: 3%; }
    .hero-float-mark.hf-cadsense { top: 26%; left: 2%; }
    .hero-float-mark.hf-solidworks { top: 24%; right: 2%; }
  }

  @media (max-width: 820px) {
    .hero {
      padding-top: 132px;
    }

    .hero-title {
      font-size: clamp(40px, 11vw, 56px);
      margin-top: 14px;
    }

    .hero-actions {
      margin-bottom: 96px;
    }

    .hero-float {
      position: absolute;
      inset: 0;
      display: block;
    }

    .hero-float-mark {
      position: absolute;
      width: 78px;
      height: 78px;
      border-radius: 20px;
    }

    .hero-float-mark img {
      width: 44px;
      height: 44px;
    }

    .hero-float-mark.hf-cadsense img {
      width: 48px;
      height: 48px;
    }

    /* Two above the title, two flanking the call-to-action area. */
    .hero-float-mark.hf-onshape {
      top: 44px;
      left: 10px;
      transform: rotate(-10deg);
    }

    .hero-float-mark.hf-codex {
      top: 44px;
      right: 10px;
      transform: rotate(8deg);
    }

    .hero-float-mark.hf-cadsense {
      top: 474px;
      left: 4px;
      right: auto;
      transform: rotate(-6deg);
    }

    .hero-float-mark.hf-solidworks {
      top: 474px;
      right: 4px;
      left: auto;
      transform: rotate(7deg);
    }
  }

  .hero-preview {
    max-width: 1180px;
    margin: 0 auto;
    transform: perspective(2000px) rotateX(2deg);
    transition: transform 0.6s ease;
  }

  .hero-preview:hover {
    transform: perspective(2000px) rotateX(0deg);
  }

  .hero-screenshot-frame {
    position: relative;
    overflow: hidden;
    aspect-ratio: 2508 / 1682;
    border-radius: 14px;
    background: #0a0a0c;
    box-shadow: 0 28px 64px -28px rgba(0, 0, 0, 0.75);
  }

  .hero-screenshot-placeholder {
    width: 100%;
    height: 100%;
    display: grid;
    place-items: center;
    background:
      linear-gradient(135deg, rgba(255, 255, 255, 0.08), rgba(255, 255, 255, 0.03)),
      linear-gradient(180deg, #1a1a1f 0%, #101015 100%);
    color: rgba(255, 255, 255, 0.48);
    font-family: var(--font-mono);
    font-size: 14px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .hero-screenshot-placeholder span {
    padding: 10px 14px;
    border: 1px dashed rgba(255, 255, 255, 0.16);
    border-radius: 999px;
  }

  /* ── Harnesses ─────────────────────────────────────────── */
  .sec-harness { background: #09090b; }

  .harness-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    overflow: hidden;
  }

  .harness {
    padding: 22px 20px;
    display: flex; align-items: center; gap: 14px;
    border-right: 1px solid var(--border);
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.015), transparent);
    transition: background 0.2s ease;
  }
  .harness:last-child { border-right: 0; }
  .harness:hover { background: rgba(255, 255, 255, 0.025); }
  .harness.is-supported {
    background:
      radial-gradient(circle at 18% 18%, rgba(32, 201, 122, 0.12), transparent 40%),
      linear-gradient(180deg, rgba(255, 255, 255, 0.025), transparent);
  }
  .harness.is-coming-soon {
    opacity: 0.58;
  }

  .harness-mark {
    color: var(--fg); opacity: 0.95;
    flex-shrink: 0; width: 28px; height: 28px;
    display: grid; place-items: center;
  }
  .harness-mark img { width: 22px; height: 22px; object-fit: contain; }

  .harness-meta { flex: 1; min-width: 0; }
  .harness-name {
    font-size: 14px; font-weight: 500;
    letter-spacing: -0.01em; margin-bottom: 2px;
  }
  .harness-tag {
    font-family: var(--font-mono);
    font-size: 11px; color: var(--fg-dim);
  }

  .harness-footer {
    display: flex; gap: 24px; flex-wrap: wrap;
    margin-top: 28px; padding-top: 24px;
    border-top: 1px dashed var(--border);
    font-size: 13px; color: var(--fg-muted);
  }
  .harness-footer-item {
    display: inline-flex; gap: 8px; align-items: center;
    color: var(--fg-muted);
  }
  .harness-footer-item svg { color: var(--ok); }

  /* ── Git ──────────────────────────────────────────────── */
  .git-inner {
    display: grid;
    grid-template-columns: 1.1fr 1fr;
    gap: 64px; align-items: center;
  }

  .git-visual {
    position: relative;
    display: flex; flex-direction: column;
    align-items: stretch; gap: 20px;
  }

  .review-card { padding: 20px; }
  .review-head {
    display: flex; align-items: center; gap: 10px;
    margin-bottom: 12px;
  }
  .review-label {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--fg-dim);
